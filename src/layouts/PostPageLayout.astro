---
import BaseLayout from './BaseLayout.astro';
import MainContentLayout from 'src/layouts/MainContenLayout.astro';
const { title } = Astro.props.frontmatter;
---

<BaseLayout>
  <MainContentLayout>
    <div class="my-3 text-light">
    <article>
      <h1 class="text-center">{title}</h1>
      <slot>
    </article>
    </div>
  </MainContentLayout>
</BaseLayout>
